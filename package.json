{
  "name": "decentralized-evoting-system",
  "version": "1.0.0",
  "description": "Decentralized E-Voting System using Blockchain Technology",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "compile": "npx hardhat compile",
    "migrate": "npx hardhat run scripts/deploy.js --network localhost",
    "test": "npx hardhat test",
    "ganache": "npx ganache --port 7545 --networkId 1337",
    "client": "cd client && npm start",
    "seed": "node server/scripts/seedAdmin.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.3.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "helmet": "^7.0.0",
    "crypto-js": "^4.1.1",
    "web3": "^4.0.3",
    "ethers": "^6.6.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "hardhat": "^2.17.0",
    "nodemon": "^3.0.1",
    "ganache": "^7.9.1"
  }
}
